# Для локального запуска БД localhost и порт 5433
DB_HOST=localhost
DB_PORT=5434
DB_NAME=orders

# Для миграций (Alembic)
DB_USER=postgres
DB_PASS=admin

# Для работы приложения
DB_APP_USER=orderflow_app
DB_APP_PASS=admin

# Локальный порт для подключения к Kafka извне
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost
KAFKA_BOOTSTRAP_SERVERS_PORT=9094

# Топик для публикации заказов и получения статусов
KAFKA_ORDER_TOPIC=order.events

# Группа для обработки order.events
KAFKA_CONSUMER_GROUP=order-service

# Частота проверки событий в мс
KAFKA_CONSUMER_TIMEOUT=1000

# Максимальное количество записей для обработки
KAFKA_CONSUMER_MAX_RECORDS=5

# Пауза перед повторной попыткой после ошибки Kafka/обработки
KAFKA_RETRY_BACKOFF_SECONDS=5

# Для локального запуска Redis localhost и порт 6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Defaut TTL
REDIS_DEFAULT_EXPIRE=60

# JWT
JWT_SECRET_KEY=d33911cef3b482cb9fafa1a7f32eb412906d05d7e348d8e0a6971999bd7ceb4d
JWT_ALGORITHM=HS256
